  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "if (res.access) {",
                  "    pm.environment.set(\"access_token\", res.access);",
                  "    console.log(\"✅ Access token saved\");",
                  "}",
                  "",
                  "if (res.refresh) {",
                  "    pm.environment.set(\"refresh_token\", res.refresh);",
                  "    console.log(\"✅ Refresh token saved\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"your_superuser_username\",\n    \"password\": \"your_superuser_password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/token/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "token",
                ""
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "if (res.access) {",
                  "    pm.environment.set(\"access_token\", res.access);",
                  "    console.log(\"✅ Access token refreshed\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/token/refresh/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "token",
                "refresh",
                ""
              ]
            }
          },
          "response": []
        }
      ]
